// GitPager Prisma schema (SQLite).
// SQLite has no native enums, so status/role/type fields are plain strings whose
// allowed values are documented inline and enforced by TypeScript unions in
// src/lib/domain.ts.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  avatarUrl   String?
  githubLogin String?
  role        String   @default("member") // "admin" | "member"
  timeZone    String   @default("Etc/UTC")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships       TeamMembership[]
  layerUsers        ScheduleLayerUser[]
  overrides         Override[]
  escalationTargets EscalationTarget[]  @relation("UserEscalationTargets")
  assignedIncidents Incident[]          @relation("AssignedIncidents")
  logEntries        IncidentLogEntry[]  @relation("LogActor")
  notifications     Notification[]
}

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships        TeamMembership[]
  services           Service[]
  schedules          Schedule[]
  escalationPolicies EscalationPolicy[]
}

model TeamMembership {
  id     String @id @default(cuid())
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  role   String @default("member") // "manager" | "member"

  @@unique([teamId, userId])
}

model Service {
  id                 String            @id @default(cuid())
  name               String
  description        String?
  status             String            @default("active") // "active" | "maintenance" | "disabled"
  integrationKey     String            @unique @default(cuid())
  team               Team?             @relation(fields: [teamId], references: [id], onDelete: SetNull)
  teamId             String?
  escalationPolicy   EscalationPolicy? @relation(fields: [escalationPolicyId], references: [id], onDelete: SetNull)
  escalationPolicyId String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  incidents Incident[]
}

model EscalationPolicy {
  id          String   @id @default(cuid())
  name        String
  description String?
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  teamId      String?
  repeatCount Int      @default(0) // times to repeat all levels if still unacknowledged
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rules     EscalationRule[]
  services  Service[]
  incidents Incident[]
}

model EscalationRule {
  id           String @id @default(cuid())
  policy       EscalationPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  policyId     String
  position     Int    // 0-based level order
  delayMinutes Int    @default(30) // escalate to next level after this many minutes unacknowledged

  targets EscalationTarget[]

  @@unique([policyId, position])
}

model EscalationTarget {
  id         String    @id @default(cuid())
  rule       EscalationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  ruleId     String
  type       String    // "user" | "schedule"
  user       User?     @relation("UserEscalationTargets", fields: [userId], references: [id], onDelete: Cascade)
  userId     String?
  schedule   Schedule? @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  scheduleId String?
}

model Schedule {
  id          String   @id @default(cuid())
  name        String
  description String?
  timeZone    String   @default("Etc/UTC")
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  teamId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  layers            ScheduleLayer[]
  overrides         Override[]
  escalationTargets EscalationTarget[]
}

model ScheduleLayer {
  id                    String   @id @default(cuid())
  schedule              Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  scheduleId            String
  name                  String
  position              Int      @default(0)
  rotationType          String   @default("weekly") // "daily" | "weekly" | "custom"
  rotationLengthSeconds Int      @default(604800)   // length of one person's on-call turn
  handoffTime           String   @default("11:00")  // HH:mm local handoff (display/alignment)
  startTime             DateTime // rotation anchor (UTC)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  users ScheduleLayerUser[]
}

model ScheduleLayerUser {
  id       String        @id @default(cuid())
  layer    ScheduleLayer @relation(fields: [layerId], references: [id], onDelete: Cascade)
  layerId  String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  position Int // order in the rotation

  @@unique([layerId, position])
}

model Override {
  id         String   @id @default(cuid())
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  scheduleId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  start      DateTime
  end        DateTime
  createdAt  DateTime @default(now())
}

model Incident {
  id                 String            @id @default(cuid())
  number             Int               @unique // human-facing incident number, assigned in app logic
  title              String
  description        String?
  status             String            @default("triggered") // "triggered" | "acknowledged" | "resolved"
  urgency            String            @default("high")       // "high" | "low"
  service            Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId          String
  escalationPolicy   EscalationPolicy? @relation(fields: [escalationPolicyId], references: [id], onDelete: SetNull)
  escalationPolicyId String?
  currentLevel       Int               @default(0)
  assignedUser       User?             @relation("AssignedIncidents", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedUserId     String?
  dedupKey           String? // for Events API deduplication of open incidents (enforced in app logic)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  resolvedAt         DateTime?

  logEntries    IncidentLogEntry[]
  notifications Notification[]

  @@index([serviceId, dedupKey])
}

model IncidentLogEntry {
  id          String   @id @default(cuid())
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  incidentId  String
  type        String   // "triggered" | "acknowledged" | "resolved" | "escalated" | "notified" | "reassigned" | "annotated"
  actor       User?    @relation("LogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorUserId String?
  message     String
  createdAt   DateTime @default(now())

  @@index([incidentId, createdAt])
}

model Notification {
  id         String   @id @default(cuid())
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  incidentId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  channel    String   @default("inapp") // "inapp" | "email" | "slack"
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId, read])
}
