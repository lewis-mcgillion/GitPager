# ---------------------------------------------------------------------------
# GitPager configuration
#
# GitPager is a static single-page app that talks to the PagerDuty REST API
# directly from the browser. There is NO server and NO client secret. Only
# public, build-time NEXT_PUBLIC_* values are needed. Copy this file to
# `.env.local` (gitignored) for local development.
#
# NEVER put a client secret here or in .env.local — a public PKCE client has no
# secret, and this repo is public.
# ---------------------------------------------------------------------------

# Client ID of your PagerDuty **Public Client (PKCE)** OAuth app. Public by
# design (it appears in the browser authorize request). Leave blank to hide the
# OAuth button and use the REST API token sign-in instead.
NEXT_PUBLIC_PAGERDUTY_CLIENT_ID=""

# PagerDuty region for your account: "eu" (api.eu.pagerduty.com) or "us"
# (api.pagerduty.com). Defaults to "eu".
NEXT_PUBLIC_PAGERDUTY_REGION="eu"

# Base path the app is served under. Empty for local dev; set to "/GitPager"
# for the GitHub Pages project site (https://<user>.github.io/GitPager). The
# Pages workflow sets this automatically from the repo name.
NEXT_PUBLIC_BASE_PATH=""

# --- Optional overrides (sensible defaults are built in) ---------------------
# Space-delimited OAuth scopes. Must be a subset of what your PKCE app was
# granted. Defaults cover read across the app plus schedules/incidents write.
# NEXT_PUBLIC_PAGERDUTY_SCOPES="openid profile email users.read teams.read schedules.read schedules.write escalation_policies.read services.read oncalls.read incidents.read incidents.write"

# Identity + API hosts (only override for non-standard setups).
# NEXT_PUBLIC_PAGERDUTY_AUTHORIZE_URL="https://identity.pagerduty.com/oauth/authorize"
# NEXT_PUBLIC_PAGERDUTY_TOKEN_URL="https://identity.pagerduty.com/oauth/token"
# NEXT_PUBLIC_PAGERDUTY_API_BASE="https://api.eu.pagerduty.com"
