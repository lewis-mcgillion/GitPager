# ---------------------------------------------------------------------------
# GitPager environment configuration
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — NEVER commit real secrets to this public repo.
# ---------------------------------------------------------------------------

# Database (SQLite file, relative to the prisma/ directory)
DATABASE_URL="file:./dev.db"

# Session signing secret (used to sign the httpOnly session cookie).
# Generate one with: openssl rand -hex 32
SESSION_SECRET="change-me-to-a-long-random-string"

# Auth mode: "dev" enables the seeded-user picker login (no external IdP needed).
# Set to "oidc" to require the real OIDC flow configured below.
AUTH_MODE="dev"

# ---------------------------------------------------------------------------
# OIDC / OAuth2 (only required when AUTH_MODE="oidc")
# Values below default toward an Okta OIDC application. The scoped OAuth client
# id/secret you were issued go in .env.local (NOT here).
# ---------------------------------------------------------------------------
OIDC_AUTHORIZE_URL="https://github.okta.com/oauth2/v1/authorize"
OIDC_TOKEN_URL="https://github.okta.com/oauth2/v1/token"
OIDC_USERINFO_URL="https://github.okta.com/oauth2/v1/userinfo"
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
OIDC_REDIRECT_URI="http://localhost:3000/api/auth/callback"
OIDC_SCOPES="openid profile email"
