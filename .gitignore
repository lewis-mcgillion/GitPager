# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files — GitPager is a public repo. Only NON-secret NEXT_PUBLIC_* config is
# ever needed at build time, and it belongs in .env.local (gitignored) or CI vars.
# NEVER commit a real secret. The confidential PagerDuty client secret must stay
# out of the tree entirely — a static site cannot use it anyway.
.env
.env*.local

# testing
/coverage

# typescript
*.tsbuildinfo
tsconfig.tsbuildinfo

# IDE
.idea
.vscode/*
!.vscode/extensions.json
