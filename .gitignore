# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files — real secrets live ONLY in .env*.local (gitignored, NEVER committed).
# The committed .env holds ONLY the non-secret local SQLite DATABASE_URL that the
# Prisma CLI needs. Do NOT put secrets (OIDC client secret, SESSION_SECRET) in .env.
.env*.local

# SQLite / Prisma database files
*.db
*.db-journal
*.sqlite
*.sqlite3
prisma/dev.db*
prisma/*.db
prisma/migrations/dev.db*

# generated Prisma client
/src/generated

# testing
/coverage

# typescript
*.tsbuildinfo

# IDE
.idea
.vscode/*
!.vscode/extensions.json
